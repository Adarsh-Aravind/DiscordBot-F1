# =============================================================================
#  Bit Beast Bot — environment configuration
#  This file holds secrets and is gitignored. Never commit it or share it.
#  After editing, restart the bot for changes to take effect.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Discord bot token
# -----------------------------------------------------------------------------
# From https://discord.com/developers/applications -> your app -> Bot -> Reset Token.
# Also enable BOTH privileged intents on that page:
#   - Message Content Intent
#   - Server Members Intent
DISCORD_TOKEN=paste_your_bot_token_here


# -----------------------------------------------------------------------------
# YouTube upload alerts
# -----------------------------------------------------------------------------
# Each value is the DISCORD channel id where that creator's new uploads are
# announced. The YouTube channel ids themselves live in cogs/youtube.py.
#
#   YT_ABITBEAST -> A Bit-Beast  (UCWOMTp0BLi41FTn6ouh_mdg)
#   YT_LETSBEAST -> Let's Beast  (UCCYq8CHiJR3Y8IEME0SgNUQ)
#   YT_BYTEBEAST -> ByteBeast    (UCrFnDVz-JgIUdyizwd6YX9g)
#   YT_REDSHIF8  -> Redshif8     (UCKK4jwSOaKBSTqQjNRbndng)
#
# ByteBeast deliberately posts to the same channel as A Bit-Beast.
YT_ABITBEAST=1478341428567347261
YT_LETSBEAST=898826137407455263
YT_BYTEBEAST=1478341428567347261
YT_REDSHIF8=1473220881454203073


# -----------------------------------------------------------------------------
# Kick live alerts
# -----------------------------------------------------------------------------
# Discord channel for "went live" announcements. The Kick slug to watch
# (abitbeast) is set in the CHANNELS map in cogs/kick.py.
KICK_CHANNEL_1=1478341428567347261

# Kick is only polled between these hours, in STREAM_TIMEZONE. Streams starting
# outside the window are NOT announced — widen it if the schedule changes.
STREAM_TIMEZONE=Asia/Kolkata
KICK_ACTIVE_START=17
KICK_ACTIVE_END=23


# -----------------------------------------------------------------------------
# Auto-moderation
# -----------------------------------------------------------------------------
# The only channel where YouTube links are allowed (besides the promo channel).
# Leave as 0 to allow YouTube links nowhere except the promo channel.
ALLOWED_YT_CHANNEL=0

# Promo channel: text posts here must contain a YouTube link or they're deleted.
PROMO_CHANNEL=764832907260198965

# Role treated as staff and exempt from every auto-moderation filter.
# (Administrators and anyone with Manage Messages / Timeout Members are
# already exempt regardless of this role.)
ADMIN_ROLE=666859807877365801


# -----------------------------------------------------------------------------
# Announcements & logging
# -----------------------------------------------------------------------------
# Where subscriber/follower milestone announcements are posted.
MILESTONE_CHANNEL=730340430155219024

# Where the bot reports Kick API errors (throttled to once per 30 min).
LOGGING_CHANNEL=830364694916890674


# -----------------------------------------------------------------------------
# OPTIONAL — YouTube Data API key
# -----------------------------------------------------------------------------
# Without a key, subscriber milestones use a free third-party estimate.
# With one, counts come from the official API. Get it from
# https://console.cloud.google.com -> enable "YouTube Data API v3" -> API key.
# YOUTUBE_API_KEY=
